{
  "version": 2,
  "env": {
    "VERCEL_ENV": "production",
    "NODE_ENV": "production"
  },
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "devCommand": "next dev",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}