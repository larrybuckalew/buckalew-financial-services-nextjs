# Application Configuration
APP_NAME=Buckalew Financial Services
APP_ENV=development
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:3000

# Database Configuration
DB_CONNECTION=mongodb
DB_HOST=127.0.0.1
DB_PORT=27017
DB_DATABASE=buckalew_financial
DB_USERNAME=
DB_PASSWORD=

# Authentication Configuration
JWT_SECRET=
JWT_EXPIRATION=1h
PASSWORD_RESET_EXPIRY=1h

# Security Settings
CSRF_PROTECTION=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=15m

# Logging Configuration
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null

# Performance Monitoring
PERFORMANCE_MONITORING_ENABLED=true
SENTRY_DSN=

# External Services
FINANCIAL_API_ENDPOINT=
FINANCIAL_API_KEY=

# Feature Flags
FEATURE_ENABLE_CHAT_SUPPORT=false
FEATURE_ENABLE_DARK_MODE=true

# Compliance and Regulations
GDPR_COMPLIANCE_MODE=strict
DATA_RETENTION_PERIOD=365  # days

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# Notification Preferences
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=false

# Analytics
ANALYTICS_PROVIDER=google
ANALYTICS_TRACKING_ID=

# Two-Factor Authentication
2FA_ENABLED=true
2FA_PROVIDER=authy