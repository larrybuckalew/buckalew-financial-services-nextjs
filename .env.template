# Application Configuration
NEXT_PUBLIC_APP_NAME=Buckalew Financial Services
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/buckalew_financial

# Authentication
JWT_SECRET=generate_a_long_random_secret_here
JWT_EXPIRATION=1h

# Security
CSRF_SECRET=generate_another_long_random_secret_here
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Monitoring and Logging
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
LOGGING_LEVEL=info

# API Keys (Replace with your actual keys)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
FINANCIAL_DATA_API_KEY=your_financial_data_api_key

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_CHAT_SUPPORT=false

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_a_unique_nextauth_secret_here

# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/buckalew_financial?schema=public"